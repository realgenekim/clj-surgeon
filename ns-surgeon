#!/usr/bin/env bb

;; ns-surgeon: structural operations on Clojure namespaces
;; Install: bbin install . --as ns-surgeon

(require '[babashka.classpath :as cp])

;; Resolve src dir relative to this script's location
(def script-dir
  (let [script (System/getProperty "babashka.file")]
    (when script
      (.getParent (java.io.File. script)))))

(cp/add-classpath (str (or script-dir ".") "/src"))

(require '[ns-surgeon.core :as core])
(apply core/-main *command-line-args*)
